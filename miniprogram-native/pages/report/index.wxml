<view class="page">
  <view wx:if="{{!hasReport}}" class="empty-state">
    <view class="title">还没有报告</view>
    <view class="subtitle">录入一次成绩后，这里会显示最近报告。</view>
    <button class="primary" bindtap="goInput">点击录入成绩</button>
  </view>

  <view wx:if="{{hasReport}}">
    <view class="app-hero section">
      <view class="hero-row">
        <view class="hero-mark">报</view>
        <view class="hero-copy">
          <view class="hero-title">AI分析报告</view>
          <view class="hero-subtitle">{{payload.student.city}} · {{payload.student.grade}} · {{examSummary}}</view>
        </view>
        <view wx:if="{{report.mock_report}}" class="status-pill">规则报告</view>
        <view wx:else class="status-pill">AI报告</view>
      </view>
      <view class="stepper">
        <view class="step done">录入方式</view>
        <view class="step done">确认成绩</view>
        <view class="step active">基础分析</view>
        <view class="step">增强报告</view>
      </view>
      <view class="hero-foot">
        <view class="hero-foot-badge">基础版</view>
        <view class="hero-foot-main">先呈现家长最关心的结论和优先学科，再继续生成增强分析。</view>
      </view>
    </view>

    <view class="panel section">
      <view class="section-title">
        <text>AI基础分析</text>
        <text class="tag tag-green">已完成</text>
      </view>
      <view class="report-summary">{{report.summary}}</view>
      <view class="export-actions">
        <button class="primary mini-button" disabled="{{exportingImage}}" bindtap="exportReportAsImage">{{exportingImage ? '导出中' : '导出图片'}}</button>
        <button class="secondary mini-button" disabled="{{exportingPdf}}" bindtap="exportReportAsPdf">{{exportingPdf ? '导出中' : '导出PDF'}}</button>
      </view>
      <view wx:if="{{report.overview}}" class="report-metric-grid">
        <view class="report-metric">
          <view class="metric-value">{{report.overview.average_score}}</view>
          <view class="metric-label">平均分</view>
        </view>
        <view class="report-metric">
          <view class="metric-value">{{report.overview.total_score}}</view>
          <view class="metric-label">个人总分</view>
        </view>
        <view class="report-metric">
          <view class="metric-value">{{report.overview.reference_total_score || '-'}}</view>
          <view class="metric-label">参考总分</view>
        </view>
      </view>
    </view>

    <view wx:if="{{report.subject_comparison && report.subject_comparison.length}}" class="panel section">
      <view class="section-title">本次考试各科成绩对比</view>
      <view class="comparison-head">
        <text>科目</text>
        <text>自己</text>
        <text>参考</text>
        <text>分差</text>
        <text>满分</text>
      </view>
      <view wx:for="{{report.subject_comparison}}" wx:key="name" class="comparison-row">
        <text class="comparison-name">{{item.name}}</text>
        <text>{{item.score}}</text>
        <text>{{item.reference_score || '-'}}</text>
        <text class="{{item.gap_to_reference && item.gap_to_reference > 0 ? 'text-warn' : 'text-good'}}">{{item.gap_to_reference || '-'}}</text>
        <text>{{item.full_score}}</text>
      </view>
      <view class="notice compact-notice">参考分来自您录入的班级/年段最好成绩；没有参考分时，系统按得分率和个人科目结构判断。</view>
    </view>

    <view wx:if="{{report.strengths && report.strengths.length}}" class="panel section">
      <view class="section-title">优势科目</view>
      <view wx:for="{{report.strengths}}" wx:key="name" class="insight-card strength-card">
        <view class="score-main">{{item.name}}</view>
        <view class="score-sub">{{item.evidence}}</view>
      </view>
    </view>

    <view wx:if="{{report.weaknesses && report.weaknesses.length}}" class="panel section">
      <view class="section-title">薄弱科目</view>
      <view wx:for="{{report.weaknesses}}" wx:key="name" class="insight-card weakness-card">
        <view class="score-main">{{item.name}}</view>
        <view class="score-sub">{{item.evidence}}</view>
      </view>
    </view>

    <view wx:if="{{report.learning_advice && report.learning_advice.length}}" class="panel section">
      <view class="section-title">学习建议</view>
      <view wx:for="{{report.learning_advice}}" wx:key="index" class="plan-card">
        <view class="workflow-index">{{index + 1}}</view>
        <view class="workflow-text">{{item}}</view>
      </view>
    </view>

    <view class="panel section">
      <view class="section-title">家长建议</view>
      <view class="muted">{{report.parent_advice}}</view>
    </view>

    <view class="panel section">
      <view class="section-title">高中选科建议</view>
      <view wx:if="{{report.elective_plan && report.elective_plan.recommendation}}" class="elective-highlight">
        <view class="elective-label">直接建议</view>
        <view class="elective-combo">{{report.elective_plan.recommendation}}</view>
        <view class="elective-reason">{{report.elective_plan.basis}}</view>
      </view>
      <view wx:elif="{{report.elective_advice}}" class="muted">{{report.elective_advice}}</view>
      <view wx:if="{{report.elective_plan && report.elective_plan.alternatives && report.elective_plan.alternatives.length}}" class="section-subtitle elective-subtitle">其他备选建议</view>
      <view wx:if="{{report.elective_plan && report.elective_plan.alternatives}}" wx:for="{{report.elective_plan.alternatives}}" wx:key="combo" class="elective-option">
        <view class="score-main">{{item.combo}}</view>
        <view class="score-sub">{{item.reason}}</view>
      </view>
      <view wx:if="{{report.elective_plan && report.elective_plan.actions && report.elective_plan.actions.length}}" class="section-subtitle elective-subtitle">下一步验证</view>
      <view wx:if="{{report.elective_plan && report.elective_plan.actions}}" wx:for="{{report.elective_plan.actions}}" wx:key="index" class="plan-card">
        <view class="workflow-index">{{index + 1}}</view>
        <view class="workflow-text">{{item}}</view>
      </view>
      <view wx:if="{{report.elective_plan && report.elective_plan.note}}" class="notice compact-notice">{{report.elective_plan.note}}</view>
      <button class="secondary full-button" bindtap="openEducationLink">查看{{city}}教育局官网</button>
    </view>

    <view class="panel section">
      <view class="section-title" bindtap="toggleTrendSection">
        <text>历史趋势</text>
        <text class="fold-toggle">{{trendExpanded ? '收起' : '展开'}}</text>
      </view>
      <view class="section-subtitle">默认折叠。这里用于判断总分和单科的持续变化，而不是只看一次考试。</view>
      <view wx:if="{{trendExpanded}}">
        <view class="metric-row">
          <view class="metric">
            <view class="metric-value">{{historyRecords.length}}</view>
            <view class="metric-label">考试次数</view>
          </view>
          <view class="metric">
            <view class="metric-value">{{trendSummary.total && trendSummary.total.diff >= 0 ? '+' : ''}}{{trendSummary.total && trendSummary.total.diff || 0}}</view>
            <view class="metric-label">总分变化</view>
          </view>
          <view class="metric">
            <view class="metric-value">{{trendSummary.total && trendSummary.total.current || 0}}</view>
            <view class="metric-label">当前总分</view>
          </view>
        </view>
        <view class="notice trend-summary-box">{{trendSummary.summary}}</view>
        <canvas id="reportTotalTrendCanvas" type="2d" class="trend-canvas"></canvas>
        <view class="section-subtitle">各科曲线趋势</view>
        <view wx:for="{{subjectTrendRows}}" wx:key="subject" class="trend-row-card">
          <view class="score-line">
            <view>
              <view class="score-main">{{item.subject}} {{item.current}}</view>
              <view class="score-sub">{{item.direction}}，波动 {{item.volatility || 0}} 分</view>
            </view>
            <text class="tag {{item.diff >= 0 ? 'tag-green' : 'tag-amber'}}">{{item.diff >= 0 ? '+' : ''}}{{item.diff || 0}}</text>
          </view>
          <canvas type="2d" class="report-subject-trend-canvas"></canvas>
        </view>
      </view>
    </view>

    <view class="enhanced-paywall section">
      <view class="enhanced-paywall-head">
        <view class="enhanced-crown">冠</view>
        <view class="enhanced-copy">
          <view class="enhanced-title">解锁 AI 增强分析</view>
          <view class="enhanced-desc">
            基础分析已经给出总分、分差、趋势和选科方向。增强分析会继续整合{{city}}与{{payload.student.grade}}特点、优势科目{{strongSubject ? '（' + strongSubject + '）' : ''}}、待提升科目{{weakSubject ? '（' + weakSubject + '）' : ''}}和阶段目标，生成更适合家长决策和学生执行的深度报告。
          </view>
          <view wx:if="{{!enhancedPurchased && !enhancedReport}}" class="enhanced-price">正式版付费解锁 · 当前调试阶段点击即模拟购买</view>
        </view>
      </view>
      <button wx:if="{{!enhancedPurchased && !enhancedReport}}" class="enhanced-buy-button" bindtap="purchaseEnhanced">立即解锁 AI 增强分析</button>
    </view>

    <view wx:if="{{enhancedPurchased || enhancedReport}}" class="panel section">
      <view class="section-title">
        <text>AI增强分析</text>
        <text wx:if="{{enhancedReport}}" class="tag tag-green">已完成</text>
        <text wx:else class="tag tag-purple">已解锁</text>
      </view>
      <view wx:if="{{!enhancedReport}}" class="notice premium-material-notice">请导入试卷照片、答题卡截图，或手动输入题型得分和丢分情况。只有补充到题型/模块级证据后，AI 才会定位具体短板；只有总分和学科分数时，不会编造阅读理解、填空题、作文等失分原因。</view>
      <view wx:if="{{!enhancedReport}}" class="section-subtitle">增强分析材料</view>
      <view wx:if="{{!enhancedReport}}" wx:for="{{materialEntries}}" wx:key="index" class="material-card">
        <view class="material-head">
          <view class="score-main">材料 {{index + 1}}</view>
          <button class="secondary mini-button" data-index="{{index}}" bindtap="removeMaterialRow">删除</button>
        </view>
        <picker range="{{subjectOptions}}" value="{{item.subjectIndex}}" data-index="{{index}}" bindchange="onMaterialSubjectChange">
          <view class="readonly-cell">{{item.subject}}</view>
        </picker>
        <textarea class="textarea material-textarea" value="{{item.detail}}" data-index="{{index}}" bindinput="onMaterialDetailInput" placeholder="例如：数学试卷，选择题12题共60分得42分；填空题4题共20分得12分；解答题-导数与函数10分得3分。" />
        <view wx:if="{{item.imagePath}}" class="material-image-box">
          <image class="upload-preview" mode="aspectFill" src="{{item.imagePath}}" />
        </view>
        <view class="upload-actions">
          <button class="primary mini-button" data-index="{{index}}" bindtap="chooseMaterialImage">上传试卷图片</button>
          <button wx:if="{{item.imagePath}}" class="secondary mini-button" data-index="{{index}}" bindtap="removeMaterialImage">移除图片</button>
        </view>
      </view>
      <button wx:if="{{!enhancedReport}}" class="secondary full-button" bindtap="addMaterialRow">确认，并添加另一门学科</button>
      <button wx:if="{{!enhancedReport}}" class="primary full-button" disabled="{{enhancedLoading}}" bindtap="generateEnhancedReport">{{enhancedLoading ? '生成中' : '生成 AI 增强分析'}}</button>

      <view wx:if="{{enhancedReport}}" class="report-card accent">
        <view class="score-main">{{enhancedReport.summary}}</view>
      </view>
      <view wx:if="{{enhancedReport}}" class="section-subtitle">整体趋势判断</view>
      <view wx:if="{{enhancedReport}}" class="notice">{{enhancedReport.overall_trend}}</view>
      <view wx:if="{{enhancedReport}}" class="section-subtitle">学科深度判断</view>
      <view wx:if="{{enhancedReport}}" wx:for="{{enhancedReport.subject_insights}}" wx:key="name" class="report-card list-item">
        <view>
          <view class="score-line">
            <view class="score-main">{{item.name}}</view>
            <text class="tag tag-purple">深度诊断</text>
          </view>
          <view class="insight-block">
            <view class="insight-label">趋势判断</view>
            <view class="score-sub">{{item.trend_judgment}}</view>
          </view>
          <view class="insight-block">
            <view class="insight-label">问题定位</view>
            <view class="score-sub">{{item.diagnosis}}</view>
          </view>
          <view class="insight-block">
            <view class="insight-label">判断依据</view>
            <view class="score-sub">{{item.evidence}}</view>
          </view>
          <view class="insight-block">
            <view class="insight-label">执行建议</view>
            <view class="score-sub">{{item.action}}</view>
          </view>
          <view class="insight-block">
            <view class="insight-label">下次目标</view>
            <view class="score-sub">{{item.next_target}}</view>
          </view>
        </view>
      </view>
      <view wx:if="{{enhancedReport}}" class="section-subtitle">风险提醒</view>
      <view wx:if="{{enhancedReport}}" wx:for="{{enhancedReport.risk_alerts}}" wx:key="index" class="warning-line">{{item}}</view>
      <view wx:if="{{enhancedReport}}" class="section-subtitle">建议补充材料</view>
      <view wx:if="{{enhancedReport}}" wx:for="{{enhancedReport.followup_materials}}" wx:key="index" class="plan-card">
        <view class="workflow-index">{{index + 1}}</view>
        <view class="workflow-text">{{item}}</view>
      </view>
      <view wx:if="{{enhancedReport}}" class="notice">{{enhancedReport.parent_focus}}</view>
      <view wx:if="{{enhancedReport}}" class="notice">{{enhancedReport.elective_note}}</view>
    </view>

    <view wx:if="{{enhancedLoading}}" class="report-mask">
      <view class="report-progress">
        <view class="report-spinner"></view>
        <view class="report-progress-title">{{enhancedProgressTitle}}</view>
        <view class="report-progress-steps">
          <view wx:for="{{enhancedProgressSteps}}" wx:key="index" class="report-progress-step">
            <view class="report-progress-dot {{index < enhancedProgressStep ? 'done' : ''}} {{index === enhancedProgressStep ? 'active' : ''}}">{{index + 1}}</view>
            <view class="report-progress-step-text">{{item}}</view>
          </view>
        </view>
        <view class="report-progress-text">{{enhancedStatusText}}</view>
      </view>
    </view>

    <view class="section">
      <view class="footer-note">{{report.disclaimer}}</view>
    </view>

    <canvas type="2d" id="reportExportCanvas" class="report-export-canvas"></canvas>

    <button class="back-action-button full-button" bindtap="goInput">重新录入</button>
  </view>

  <view class="page-version">当前版本 {{versionLabel}}</view>
  <view class="safe-area-bottom"></view>
</view>
