<view class="page">
  <view class="app-hero section">
    <view class="hero-row">
      <view class="hero-mark">录</view>
      <view class="hero-copy">
        <view class="hero-title">录入成绩</view>
        <view class="hero-subtitle">先把成绩整理成结构化数据，再交给 AI 生成报告。</view>
      </view>
    </view>
    <view class="stepper">
      <view class="step active">录入方式</view>
      <view class="step">确认成绩</view>
      <view class="step">基础分析</view>
      <view class="step">增强报告</view>
    </view>
  </view>

  <view class="panel section">
    <view class="segmented">
      <view class="segment {{textModeClass}}" data-mode="text" bindtap="switchMode">文字录入</view>
      <view class="segment {{imageModeClass}}" data-mode="image" bindtap="switchMode">截图识别</view>
    </view>
    <view class="mode-summary">
      <view class="mode-icon">{{modeIcon}}</view>
      <view class="mode-text">{{modeText}}</view>
    </view>
  </view>

  <view class="panel section">
    <view class="section-title">基础信息</view>
    <view class="form-grid">
      <view class="field-card">
        <label class="label">考试时间 <text class="required">*</text></label>
        <picker mode="date" value="{{examDate}}" bindchange="onExamDateChange">
          <view class="input picker-display">{{examDate || '请选择考试日期'}}</view>
        </picker>
      </view>

      <view class="field-card">
        <label class="label">考试名称</label>
        <input class="input" value="{{examName}}" bindinput="onExamInput" placeholder="例如期中考试（可选）" />
      </view>

      <view class="field-card">
        <label class="label">年级</label>
        <input class="input" value="{{grade}}" bindinput="onGradeInput" placeholder="高一" />
      </view>

      <view class="field-card">
        <label class="label">所在城市</label>
        <input class="input" value="{{city}}" bindinput="onCityInput" placeholder="杭州" />
      </view>
    </view>
  </view>

  <view class="panel section" wx:if="{{showTextMode}}">
    <view class="section-title">成绩描述</view>
    <view class="notice">可以直接输入九门成绩，例如“语文：90，数学：95，英语：115，物理：75，化学：70，生物：85，政治：78，历史：85，地理：85”。</view>
    <textarea class="textarea" value="{{text}}" bindinput="onTextInput" placeholder="例如：语文：90，数学：95，英语：115，物理：75，化学：70，生物：85，政治：78，历史：85，地理：85" />
    <button class="primary full-button" loading="{{loading}}" bindtap="parseScore">解析并确认</button>
  </view>

  <view class="panel section" wx:if="{{showImageMode}}">
    <view class="section-title">成绩截图</view>
    <view class="notice">上传两类截图后，先识别个人成绩，再识别班级/年段最好成绩和排名，用于生成更有对比价值的报告。</view>

    <view class="upload-grid">
      <view class="upload-card {{myImageClass}}">
        <view class="upload-head">
          <view>
            <view class="upload-title">个人成绩截图</view>
            <view class="upload-desc">导入学生本人成绩单、考试截图或照片。</view>
          </view>
          <text class="tag tag-blue">必填</text>
        </view>
        <image wx:if="{{myImage.path}}" class="upload-preview" mode="aspectFill" src="{{myImage.path}}" />
        <view wx:else class="upload-placeholder">选择清晰的个人成绩截图</view>
        <view class="upload-actions">
          <button class="primary mini-button" data-type="my" bindtap="chooseImage">选择图片</button>
          <button wx:if="{{myImage.path}}" class="secondary mini-button" data-type="my" bindtap="removeImage">移除</button>
        </view>
      </view>

      <view class="upload-card {{maxImageClass}}">
        <view class="upload-head">
          <view>
            <view class="upload-title">班级/年段最好成绩和排名</view>
            <view class="upload-desc">导入班级最高分、年段最高分、排名或对比成绩截图。</view>
          </view>
          <text class="tag tag-amber">推荐</text>
        </view>
        <image wx:if="{{maxImage.path}}" class="upload-preview" mode="aspectFill" src="{{maxImage.path}}" />
        <view wx:else class="upload-placeholder">可选：最高分、排名或对比图</view>
        <view class="upload-actions">
          <button class="primary mini-button" data-type="max" bindtap="chooseImage">选择图片</button>
          <button wx:if="{{maxImage.path}}" class="secondary mini-button" data-type="max" bindtap="removeImage">移除</button>
        </view>
      </view>
    </view>

    <button class="primary full-button" loading="{{ocrLoading}}" bindtap="recognizeImages">开始识别并确认</button>
  </view>

  <view wx:if="{{ocrLoading}}" class="report-mask">
    <view class="report-progress">
      <view class="report-spinner"></view>
      <view class="report-progress-title">{{ocrProgressTitle}}</view>
      <view class="report-progress-steps">
        <view wx:for="{{ocrProgressSteps}}" wx:key="index" class="report-progress-step">
          <view class="report-progress-dot {{index < ocrProgressStep ? 'done' : ''}} {{index === ocrProgressStep ? 'active' : ''}}">{{index + 1}}</view>
          <view class="report-progress-step-text">{{item}}</view>
        </view>
      </view>
      <view class="report-progress-text">{{ocrProgressText}}</view>
    </view>
  </view>

  <view class="page-version">当前版本 {{versionLabel}}</view>
  <view class="safe-area-bottom"></view>
</view>
